{
  "name": "line-splitter",
  "description": "Transform stream for line splitting",
  "version": "0.8.0",
  "author": "Codenautas <codenautas@googlegroups.com>",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "repository": "emilioplatzer/line-splitter",
  "contributors": [
    {
      "name": "Emilio Platzer",
      "email": "emilioplatzer@gmail.com"
    }
  ],
  "overrides": {
    "diff": ">=8.0.2",
    "serialize-javascript": ">=7.0.0",
    "uuid": ">=14.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "best-globals": "^0.10.24",
    "discrepances": "^0.2.4",
    "mocha": "^11.7.1",
    "nyc": "^17.1.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "main": "dist/server/line-splitter.js",
  "types": "dist/server/line-splitter.d.ts",
  "engines": {
    "node": ">= 8"
  },
  "scripts": {
    "tsc": "tsc",
    "test": "mocha --reporter spec --bail --check-leaks --exit",
    "test-ci": "nyc --reporter=lcov --reporter=text-lcov mocha --exit --check-leaks",
    "test-cov": "nyc mocha --exit --check-leaks",
    "build": "tsc -p tsconfig-server.json && tsc -p tsconfig-test.json",
    "build-without-err": "(tsc -p tsconfig-server.json || echo \"continue w/error\") && (tsc -p tsconfig-test.json  || echo \"continue w/error\")"
  },
  "nyc": {
    "extension": [
      ".js",
      ".ts"
    ],
    "exclude": [
      "**/*.d.ts",
      "src/test"
    ],
    "include": [
      "dist/**/*.js",
      "src/server/**"
    ],
    "x-require": [
      "ts-node/register"
    ],
    "reporter": [
      "html",
      "lcov",
      "text-summary"
    ],
    "sourceMap": true,
    "instrument": true,
    "all": true,
    "check-coverage": true
  },
  "qa-control": {
    "package-version": "0.3.0",
    "run-in": "server",
    "test-appveyor": true,
    "type": "lib",
    "stage": "designing",
    "coverage": 100
  }
}
